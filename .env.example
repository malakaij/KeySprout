DATABASE_URL="postgresql://user:password@localhost:5432/keysprout"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Share this only with staff. Anyone who knows it can register as a teacher.
TEACHER_ACCESS_CODE="your-secret-teacher-code"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="choose-a-strong-password"

# Optional — leave blank to use defaults
# Log verbosity: error | warn | info | debug (default: info)
LOG_LEVEL="info"

# Sentry error monitoring — get your DSN from sentry.io/settings/<org>/projects/<project>/keys/
# Leave blank to disable Sentry (safe default for local development)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
