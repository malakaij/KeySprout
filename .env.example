DATABASE_URL="postgresql://user:password@localhost:5432/keysprout"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Share this only with staff. Anyone who knows it can register as a teacher.
TEACHER_ACCESS_CODE="your-secret-teacher-code"

# Super-Admin credentials (deployment-level access — seeding, database ops).
# SUPER_ADMIN_PASSWORD must be a bcrypt hash, not a plaintext password.
# Generate one: node -e "require('bcryptjs').hash('your-password',12).then(console.log)"
SUPER_ADMIN_USERNAME="admin"
SUPER_ADMIN_PASSWORD="$2a$12$replacethiswitharealhash................................"

# Optional — leave blank to use defaults
# Log verbosity: error | warn | info | debug (default: info)
LOG_LEVEL="info"
